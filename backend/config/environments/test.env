NODE_ENV=test
PORT=5055

MONGODB_URI=mongodb://127.0.0.1:27017/bank_management_system_test
JWT_SECRET=test_jwt_secret_change_me
JWT_REFRESH_SECRET=test_refresh_secret_change_me

# Frontend origins
FRONTEND_URL=https://your-app.vercel.app
# Optional comma-separated additional origins (preview/custom domains)
FRONTEND_URLS=https://your-app-git-main-yourteam.vercel.app,https://your-custom-domain.com

# Required for cross-site auth cookies (Vercel frontend -> Render backend)
COOKIE_SAME_SITE=none

# Optional tuning
JWT_EXPIRE_DAYS=7
JWT_REFRESH_EXPIRE_DAYS=30
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
ENABLE_DB_TRANSACTIONS=false
