NODE_ENV=production
PORT=5000

MONGODB_URI=
JWT_SECRET=
JWT_REFRESH_SECRET=

# Frontend origins
FRONTEND_URL=https://your-app.vercel.app
# Optional comma-separated additional origins (preview/custom domains)
FRONTEND_URLS=https://your-app-git-main-yourteam.vercel.app,https://your-custom-domain.com

# Required for cross-site auth cookies (Vercel frontend -> Render backend)
COOKIE_SAME_SITE=none

# Optional tuning
JWT_EXPIRE_DAYS=7
JWT_REFRESH_EXPIRE_DAYS=30
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
